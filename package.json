{
  "name": "web-terraria",
  "version": "1.0.0",
  "description": "A web-based Terraria clone built with Phaser.js",
  "main": "index.html",
  "scripts": {
    "start": "python -m http.server 8080 || npx http-server -p 8080",
    "test": "node -c assets/js/game.js",
    "build": "echo 'No build step required - runs directly in browser'"
  },
  "keywords": [
    "terraria",
